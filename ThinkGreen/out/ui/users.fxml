<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="ui.UserController"
      stylesheets="@styles.css" prefWidth="1200" prefHeight="750">

    <!-- ════ SIDEBAR ════ -->
    <VBox styleClass="sidebar" spacing="0">
        <Label text="🌿 ThinkGreen" styleClass="sidebar-brand" />
        <Label text="Jardinage Urbain" styleClass="sidebar-tagline" />
        <Region styleClass="sidebar-divider" />
        <Label text="NAVIGATION" styleClass="nav-section-label" />
        <Button text="📊  Tableau de Bord" styleClass="nav-btn" onAction="#goToDashboard" />
        <Button text="🌱  Mes Plantes" styleClass="nav-btn" onAction="#goToPlants" />
        <Button text="👥  Utilisateurs" styleClass="nav-btn, nav-btn-active" onAction="#goToUsers" />
        <Button text="⛅  Météo / Alertes" styleClass="nav-btn" onAction="#goToWeather" />
        <Button text="💧  Planning Arrosage" styleClass="nav-btn" onAction="#goToSchedule" />
        <Region VBox.vgrow="ALWAYS" />
        <Region styleClass="sidebar-divider" />
        <Label fx:id="userInfoLabel" text="" styleClass="nav-section-label" />
        <Button text="🚪  Déconnexion" styleClass="nav-btn, nav-btn-logout" onAction="#handleLogout" />
        <Region prefHeight="15" />
    </VBox>

    <!-- ════ CONTENT ════ -->
    <VBox styleClass="content-area" HBox.hgrow="ALWAYS">

        <VBox styleClass="page-header">
            <Label text="👥 Gestion des Utilisateurs" styleClass="page-title" />
            <Label text="Consultez et gérez les comptes utilisateurs" styleClass="page-subtitle" />
        </VBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
            <VBox styleClass="page-body" spacing="20">

                <!-- Stats -->
                <HBox spacing="18">
                    <VBox styleClass="stat-card, stat-card-blue" HBox.hgrow="ALWAYS">
                        <Label text="👥" styleClass="stat-icon" />
                        <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value" />
                        <Label text="Total Utilisateurs" styleClass="stat-label" />
                    </VBox>
                    <VBox styleClass="stat-card, stat-card-green" HBox.hgrow="ALWAYS">
                        <Label text="🛡" styleClass="stat-icon" />
                        <Label fx:id="adminCountLabel" text="0" styleClass="stat-value" />
                        <Label text="Administrateurs" styleClass="stat-label" />
                    </VBox>
                    <VBox styleClass="stat-card, stat-card-amber" HBox.hgrow="ALWAYS">
                        <Label text="🌱" styleClass="stat-icon" />
                        <Label fx:id="userCountLabel" text="0" styleClass="stat-value" />
                        <Label text="Jardiniers" styleClass="stat-label" />
                    </VBox>
                </HBox>

                <!-- Table -->
                <VBox styleClass="card" spacing="12">
                    <Label text="Liste des Utilisateurs" styleClass="card-title" />
                    <TableView fx:id="usersTable" prefHeight="400">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                            <TableColumn fx:id="colUsername" text="Nom d'utilisateur" prefWidth="180" />
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="220" />
                            <TableColumn fx:id="colRole" text="Rôle" prefWidth="120" />
                            <TableColumn fx:id="colCreated" text="Inscrit le" prefWidth="150" />
                            <TableColumn fx:id="colActions" text="Actions" prefWidth="120" />
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
